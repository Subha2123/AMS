extends layout

block content
  .row.justify-content-center.loginform
    .col-md-6
      h2.mb-4.text-center Login
      form(method="POST", action="/api/auth/login")
        if error 
           .alert.alert-danger=error
        if success 
           .alert.alert-success=success
        .mb-3
          label.form-label(for="email").required Email
          input#email.form-control(type="email", name="email", placeholder="Enter email", required)
        .mb-3
          label.form-label(for="password") 
          | Password 
          span.text-danger *
          input#password.form-control(type="password", name="password", placeholder="Enter password", required)
        button.btn.btn-primary.w-100(type="submit") Login
      p.text-center.mt-3
        | Don't have an account? 
        a(href="/api/auth/register") Register here
